{
  "name": "ds-token-test",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "prepare": "pnpm codegen",
    "codegen": "pnpm codegen:role-first && pnpm codegen:property-first",
    "codegen:role-first": "panda codegen --config panda.config.role-first.ts",
    "codegen:property-first": "panda codegen --config panda.config.property-first.ts",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "check-types": "tsc --noEmit",
    "test:parity": "tsx src/tokens/semanticColors/__tests__/tokenParity.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@ark-ui/react": "^5.37.0",
    "@park-ui/panda-preset": "^0.43.1",
    "lucide-react": "^1.17.0",
    "next": "14.2.5",
    "react": "19.1.1",
    "react-dom": "19.1.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@pandacss/dev": "1.8.2",
    "@pandacss/token-dictionary": "1.8.2",
    "@pandacss/types": "1.8.2",
    "@storybook/addon-a11y": "^10.4.2",
    "@storybook/addon-docs": "^10.4.2",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.2",
    "@storybook/nextjs-vite": "^10.4.2",
    "@types/node": "^22.14.1",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "playwright": "^1.60.0",
    "storybook": "^10.4.2",
    "tsx": "^4.22.4",
    "typescript": "~5.8.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
